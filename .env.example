PORT=10000
NODE_ENV=development
BROKER_MODE=disabled

# Protects POST/write endpoints when set. Required on Render/production.
ADMIN_TOKEN=change-me-before-production

# Persistent disk paths.
DB_PATH=./data/tradingmint-db.json
SQLITE_PATH=./data/tradingmint.sqlite

# Universe controls.
SCAN_LIMIT=120
HISTORICAL_RANGE=3y
# Comma-separated extra tickers appended to the default scanner universe.
EXTRA_SYMBOLS=
# Optional: replace default universe entirely with this comma-separated list.
STOCK_SYMBOLS=
